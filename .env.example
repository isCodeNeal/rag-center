# ----- Application -----
APP_ENV=local
LOG_LEVEL=INFO
# 日志文件目录与滚动策略
LOG_DIR=logs
LOG_TO_FILE=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
# 是否记录请求/响应体（生产可设为 false 降噪/脱敏）
LOG_REQUEST_BODY=true

# ----- Database (PostgreSQL 16 + pgvector) -----
# psycopg3 driver name; used by both the async app engine and (sync) Alembic.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_center

# ----- Embedding model (OpenAI-compatible provider) -----
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=your-api-key
EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector dimension of EMBEDDING_MODEL (text-embedding-3-small = 1536).
EMBEDDING_DIM=1536

# ----- Vector store -----
VECTOR_STORE=pgvector

# ----- Chunking / retrieval -----
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5

# ----- 通用大模型 provider（rerank / query rewrite 等能力共用） -----
# 第一版仅支持 openai_compatible；DeepSeek、百炼等 OpenAI 协议兼容厂商都走这里。
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
# 如果切换到百炼 DashScope 的 OpenAI-compatible 模式，只需要改下面三行：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ----- 重排（rerank） -----
RERANK_ENABLED=false
# 第一版支持 llm（调用大模型打分）和 noop（不重排，直接按向量分数截断）。
RERANK_PROVIDER=llm
RERANK_TOP_N=5
RERANK_MAX_CANDIDATES=20
RERANK_CHUNK_MAX_CHARS=1000
RERANK_TEMPERATURE=0.0
