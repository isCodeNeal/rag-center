# ----- Application -----
APP_ENV=local
LOG_LEVEL=INFO
# 日志文件目录与滚动策略
LOG_DIR=logs
LOG_TO_FILE=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
# 是否记录请求/响应体（生产可设为 false 降噪/脱敏）
LOG_REQUEST_BODY=true

# ----- Database (PostgreSQL 16 + pgvector) -----
# psycopg3 driver name; used by both the async app engine and (sync) Alembic.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_center

# ----- Embedding model (OpenAI-compatible provider) -----
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=your-api-key
EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector dimension of EMBEDDING_MODEL (text-embedding-3-small = 1536).
EMBEDDING_DIM=1536

# ----- Vector store -----
VECTOR_STORE=pgvector

# ----- Chunking / retrieval -----
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5

# ----- 通用大模型 provider（rerank / query rewrite 等能力共用） -----
# 第一版仅支持 openai_compatible；DeepSeek、百炼等 OpenAI 协议兼容厂商都走这里。
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
# 如果切换到百炼 DashScope 的 OpenAI-compatible 模式，只需要改下面三行：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ----- 重排（rerank） -----
RERANK_ENABLED=false
# 第一版支持 llm（调用大模型打分）和 noop（不重排，直接按向量分数截断）。
RERANK_PROVIDER=llm
RERANK_TOP_N=5
RERANK_MAX_CANDIDATES=20
RERANK_CHUNK_MAX_CHARS=1000
RERANK_TEMPERATURE=0.0

# ----- 提问语义优化：LLM 改问法（query rewrite） -----
# 全局默认关闭，避免所有请求被动调用 LLM；可在请求级 query_options 覆盖。
# LLM 模型复用上面的 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL，不单独配置。
# 词表扩展（synonyms）无全局开关，只要 kb.settings 有配置即尝试。
QUERY_REWRITE_ENABLED=false
QUERY_REWRITE_TIMEOUT_MS=2000

# ----- 关键词检索（Elasticsearch BM25，用于混合检索）-----
# 第一版 provider 为 elasticsearch；后续可扩展 opensearch。
KEYWORD_SEARCH_PROVIDER=elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=rag_chunks
# title/content 分词器；IK 需 ES 安装 analysis-ik 插件（见 docker/es/Dockerfile）。
# 若环境未装 IK，可临时改为 "standard" 兜底（中文分词效果会变差）。
ELASTICSEARCH_ANALYZER=ik_max_word
ELASTICSEARCH_SEARCH_ANALYZER=ik_smart

# ----- 检索模式与混合检索（RRF 融合）-----
# retrieval_mode 默认检索模式："vector" / "bm25" / "hybrid"。
RETRIEVAL_MODE=vector
HYBRID_FUSION=rrf
HYBRID_RRF_K=60
HYBRID_VECTOR_TOP_K=20
HYBRID_BM25_TOP_K=20
HYBRID_TOP_N=20

# 是否启用多租户 API Key 鉴权（本地调试可设 false）
AUTH_ENABLED=true


# ----- Celery / Redis（异步文档索引） -----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ----- Langfuse 可观测性（检索 trace 追踪） -----
# 关闭时所有 Langfuse 操作静默跳过，retrieve 正常返回，trace_id 为 null。
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
